
###> symfony/framework-bundle ###
APP_SECRET=dev-not-a-real-secret
###< symfony/framework-bundle ###

###> app/hr-api ###
# Dev-only HR API connection: the local mock and its demo token. These are
# intentionally NOT in .env, so a non-dev environment that forgets to inject the
# real HR_API_TOKEN fails loudly ("env var not found") rather than silently
# falling back to localhost. Production injects the real values via its secret store.
HR_API_BASE_URL=http://127.0.0.1:8081
HR_API_TOKEN=demo-secret-token-7Qx2
###< app/hr-api ###
